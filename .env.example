# 墨境图像工作台默认不需要 .env。
# API URL 和 API Key 在网页右上角“设置”里填写，并保存在本机浏览器 localStorage。

# 婚纱样片工作台邮箱验证码（identity-workflow）
# 示例：QQ 邮箱一般是 smtp.qq.com / 465 / secure=true，密码用授权码，不要用登录密码。
IDENTITY_WORKFLOW_SMTP_HOST=
IDENTITY_WORKFLOW_SMTP_PORT=587
IDENTITY_WORKFLOW_SMTP_SECURE=false
IDENTITY_WORKFLOW_SMTP_USER=
IDENTITY_WORKFLOW_SMTP_PASS=
IDENTITY_WORKFLOW_MAIL_FROM=

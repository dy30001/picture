# 墨境图像工作台默认不需要 .env。
# API URL 和 API Key 在网页右上角“设置”里填写，并保存在本机浏览器 localStorage。

# 如果客户选片台和生图工具还没有真正融合成同一个 9999 服务，
# 这里要显式指向实际生图工具地址，避免客户选片台把工具地址回推成当前自己的 9999。
IMAGE_WORKBENCH_URL=
IMAGE_WORKBENCH_PORT=9999

# 支付与积分充值（Stripe Checkout）
# APP_BASE_URL 用于 Stripe 支付完成后跳回当前站点，例如 http://127.0.0.1:9999 或 https://your-domain.com
APP_BASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=cny
# 本地联调整体流程时可临时打开，正式环境不要开启。
STRIPE_FAKE_MODE=false
# 如需自定义支付完成/取消回跳地址，可显式填写完整 URL；留空则默认回到 APP_BASE_URL 首页。
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=

# Inklens 站内邮箱注册码
# 示例：QQ 邮箱一般是 smtp.qq.com / 465 / secure=true，密码用授权码，不要用登录密码。
INKLENS_SMTP_HOST=
INKLENS_SMTP_PORT=587
INKLENS_SMTP_SECURE=false
INKLENS_SMTP_USER=
INKLENS_SMTP_PASS=
INKLENS_MAIL_FROM="墨境 <your@email.com>"
INKLENS_AUTH_TEST_MODE=0

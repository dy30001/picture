# 墨境图像工作台默认不需要 .env。
# API URL 和 API Key 在网页右上角“设置”里填写，并保存在本机浏览器 localStorage。

# 数据存储后端
# file: 继续使用本地 JSON 文件
# postgres: 用户、验证码、积分、订单、历史记录全部写入 PostgreSQL
APP_STORAGE_BACKEND=file

# PostgreSQL（建议正式环境使用）
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=墨境图片客户库
POSTGRES_USER=墨境图片用户
POSTGRES_PASSWORD=
POSTGRES_POOL_MAX=10
POSTGRES_CONNECTION_TIMEOUT_MS=10000
POSTGRES_IDLE_TIMEOUT_MS=30000

# 初始化本地 PostgreSQL 时使用；不需要可留空
POSTGRES_ADMIN_HOST=127.0.0.1
POSTGRES_ADMIN_PORT=5432
POSTGRES_ADMIN_DATABASE=postgres
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=

# 如果客户选片台和生图工具还没有真正融合成同一个 9999 服务，
# 这里要显式指向实际生图工具地址，避免客户选片台把工具地址回推成当前自己的 9999。
IMAGE_WORKBENCH_URL=
IMAGE_WORKBENCH_PORT=9999

# 智能生图 OpenAI-compatible 通道。密钥只写本机 .env，不要提交真实值。
INKLENS_IMAGE_API_URL=https://alexai.work/v1
INKLENS_IMAGE_API_KEY=
INKLENS_IMAGE_API_MODE=images
INKLENS_IMAGE_MODEL_ID=gpt-image-2
INKLENS_IMAGE_MAIN_MODEL_ID=gpt-5.5
INKLENS_IMAGE_TIMEOUT_SECONDS=120

# 支付与积分充值
# APP_BASE_URL 用于支付完成后跳回当前站点，例如 http://127.0.0.1:9999 或 https://your-domain.com
APP_BASE_URL=https://img.inklens.art

# 支付宝网页支付（推荐国内收款优先使用）
# 下面两个是必填：
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
# 可选但强烈建议：配置后可校验异步通知和网关响应签名。
# 如果暂时未配置，系统仍可在支付成功回跳页主动查询并确认到账。
ALIPAY_PUBLIC_KEY=
# 默认正式网关；如需沙箱可改成 https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# 可选：如果不填，会默认回到 APP_BASE_URL 下的 /api/payments/alipay/return 和 /notify
ALIPAY_RETURN_URL=
ALIPAY_NOTIFY_URL=

# Stripe Checkout（备用）
STRIPE_SECRET_KEY=
# 可选但强烈建议：配置后 Stripe 会异步回写到账。
# 如果暂时未配置，系统会在支付成功回跳页用 session_id 主动确认到账。
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=cny
# 本地联调整体流程时可临时打开，正式环境不要开启。
STRIPE_FAKE_MODE=false
# 可选：auto / alipay / stripe；默认 auto，会优先选择已配置完成的支付宝。
PAYMENT_PROVIDER=auto
# 如需自定义支付完成/取消回跳地址，可显式填写完整 URL；留空则默认回到 APP_BASE_URL 首页。
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=

# Inklens 站内邮箱注册码
# 示例：QQ 邮箱一般是 smtp.qq.com / 465 / secure=true，密码用授权码，不要用登录密码。
INKLENS_SMTP_HOST=
INKLENS_SMTP_PORT=587
INKLENS_SMTP_SECURE=false
INKLENS_SMTP_USER=
INKLENS_SMTP_PASS=
INKLENS_MAIL_FROM="墨境 <your@email.com>"
INKLENS_AUTH_TEST_MODE=0
